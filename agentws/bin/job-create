#!/usr/bin/env bash
set -euo pipefail

AGENTWS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
JOBS_DIR="$AGENTWS_ROOT/jobs"

usage() {
    echo "Usage: job-create <job-id> -t <type> [spec-file]"
    echo ""
    echo "Create a new job with a given type."
    echo "If spec-file is provided, it is copied into the job."
    echo "Otherwise, an empty spec.md is created for you to edit."
    echo ""
    echo "Types are free-form strings used to route jobs to agents."
    echo "Examples: code, review, research, refactor, test"
    exit 1
}

JOB_ID=""
JOB_TYPE=""
SPEC_FILE=""

while [ $# -gt 0 ]; do
    case "$1" in
        -t) JOB_TYPE="$2"; shift 2 ;;
        --help|-h) usage ;;
        *)
            if [ -z "$JOB_ID" ]; then
                JOB_ID="$1"
            else
                SPEC_FILE="$1"
            fi
            shift
            ;;
    esac
done

[ -z "$JOB_ID" ] && usage
[ -z "$JOB_TYPE" ] && { echo "error: job type required (-t <type>)" >&2; exit 1; }

JOB_DIR="$JOBS_DIR/$JOB_ID"

if [ -d "$JOB_DIR" ]; then
    echo "error: job '$JOB_ID' already exists" >&2
    exit 1
fi

mkdir -p "$JOB_DIR/workspace"

if [ -n "$SPEC_FILE" ]; then
    cp "$SPEC_FILE" "$JOB_DIR/spec.md"
else
    cat > "$JOB_DIR/spec.md" <<'EOF'
# Job Specification

## Objective

<!-- What needs to be done -->

## Acceptance Criteria

<!-- How to know it's done -->

## Notes

<!-- Any additional context -->
EOF
fi

echo "pending" > "$JOB_DIR/status"
echo "$JOB_TYPE" > "$JOB_DIR/type"
touch "$JOB_DIR/log.md"

echo "created: $JOB_DIR (type: $JOB_TYPE)"
echo "edit spec: $JOB_DIR/spec.md"
