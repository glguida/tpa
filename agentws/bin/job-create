#!/usr/bin/env bash
set -euo pipefail

AGENTWS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
. "$AGENTWS_ROOT/bin/lib-agentws"

usage() {
    echo "Usage: job-create <job-id> -t <type> <spec-file>"
    echo ""
    echo "Create a new job with a given type and complete spec."
    echo "The spec file is copied into the job before it becomes pending."
    echo ""
    echo "Types are free-form strings used to route jobs to roles."
    exit 1
}

JOB_ID=""
JOB_TYPE=""
SPEC_FILE=""

while [ $# -gt 0 ]; do
    case "$1" in
        -t)
            [ $# -ge 2 ] || die "-t requires a type"
            JOB_TYPE="$2"
            shift 2
            ;;
        --help|-h) usage ;;
        *)
            if [ -z "$JOB_ID" ]; then
                JOB_ID="$1"
            elif [ -z "$SPEC_FILE" ]; then
                SPEC_FILE="$1"
            else
                die "unexpected argument '$1'"
            fi
            shift
            ;;
    esac
done

[ -z "$JOB_ID" ] && usage
[ -z "$JOB_TYPE" ] && die "job type required (-t <type>)"
[ -z "$SPEC_FILE" ] && die "spec file required"
[ "$SPEC_FILE" = "-" ] && die "pass a spec file path, not stdin"
[ ! -f "$SPEC_FILE" ] && die "spec file '$SPEC_FILE' does not exist"
[ ! -s "$SPEC_FILE" ] && die "spec file '$SPEC_FILE' is empty"

validate_job_id "$JOB_ID"
require_jobs_dir
JOB_DIR="$JOBS_DIR/$JOB_ID"

# Atomic mkdir - fails if job dir already exists (prevents TOCTOU race)
if ! mkdir "$JOB_DIR" 2>/dev/null; then
    die "job '$JOB_ID' already exists"
fi
mkdir "$JOB_DIR/workspace"
cp "$SPEC_FILE" "$JOB_DIR/spec.md"

echo "$JOB_TYPE" > "$JOB_DIR/type"
touch "$JOB_DIR/log.md"
echo "pending" > "$JOB_DIR/status"

echo "created: $JOB_DIR (type: $JOB_TYPE)"
echo "spec: $JOB_DIR/spec.md"
