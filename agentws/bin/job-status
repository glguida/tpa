#!/usr/bin/env bash
set -euo pipefail

AGENTWS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
JOBS_DIR="$AGENTWS_ROOT/jobs"

VALID_STATUSES="pending claimed running review done failed"

usage() {
    echo "Usage: job-status <job-id> [new-status]"
    echo ""
    echo "Get or set job status."
    echo "Valid statuses: $VALID_STATUSES"
    exit 1
}

[ $# -lt 1 ] && usage

JOB_ID="$1"
NEW_STATUS="${2:-}"
JOB_DIR="$JOBS_DIR/$JOB_ID"

if [ ! -d "$JOB_DIR" ]; then
    echo "error: job '$JOB_ID' does not exist" >&2
    exit 1
fi

# Get mode
if [ -z "$NEW_STATUS" ]; then
    cat "$JOB_DIR/status"
    exit 0
fi

# Validate status
valid=0
for s in $VALID_STATUSES; do
    [ "$s" = "$NEW_STATUS" ] && valid=1
done
if [ "$valid" -eq 0 ]; then
    echo "error: invalid status '$NEW_STATUS'" >&2
    echo "valid statuses: $VALID_STATUSES" >&2
    exit 1
fi

OLD_STATUS=$(cat "$JOB_DIR/status" 2>/dev/null || echo "unknown")

# If transitioning to done or failed, release the lock
if [ "$NEW_STATUS" = "done" ] || [ "$NEW_STATUS" = "failed" ]; then
    rmdir "$JOB_DIR/lock" 2>/dev/null || true
fi

# If resetting to pending, release lock and clear agent
if [ "$NEW_STATUS" = "pending" ]; then
    rmdir "$JOB_DIR/lock" 2>/dev/null || true
    rm -f "$JOB_DIR/agent.id"
fi

echo "$NEW_STATUS" > "$JOB_DIR/status"
echo "$JOB_ID: $OLD_STATUS -> $NEW_STATUS"
