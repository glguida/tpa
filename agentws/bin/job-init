#!/usr/bin/env bash
set -euo pipefail

AGENTWS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
JOBS_DIR="$AGENTWS_ROOT/jobs"

if [ -d "$JOBS_DIR" ]; then
    echo "jobs/ directory already exists."
else
    mkdir -p "$JOBS_DIR"
    echo "Created jobs/ directory."
fi

echo "AgentWS initialized at: $AGENTWS_ROOT"
echo ""
echo "Next steps:"
echo "  1. Create a job:  bin/job-create my-first-job -t plan"
echo "  2. Edit the spec:  \$EDITOR jobs/my-first-job/spec.md"
echo "  3. Launch agents:  pi \"You are a plan agent.\""
