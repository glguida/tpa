#!/usr/bin/env bash
set -euo pipefail

AGENTWS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
. "$AGENTWS_ROOT/bin/lib-agentws"

if [ -d "$JOBS_DIR" ]; then
    echo "jobs/ directory already exists."
else
    mkdir -p "$JOBS_DIR"
    echo "Created jobs/ directory."
fi

echo "AgentWS initialized at: $AGENTWS_ROOT"
echo ""
echo "Next steps:"
echo "  1. Write a complete spec:  \$EDITOR /tmp/my-first-job-spec.md"
echo "  2. Create the job:         bin/job-create my-first-job -t <type> /tmp/my-first-job-spec.md"
echo "  3. Launch agents with their assigned roles."
