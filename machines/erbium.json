{
  "kind": "erbium",
  "description": "Current Erbium runtime shape: one local domain with the useful minions sharing local memory.",
  "comm_cost_default": 0.1,
  "comm_cost_local": 0.1,
  "comm_cost_fabric": 5.0,
  "comm_cost_external": 50.0,
  "context_grid": {
    "devices": ["erbium0"],
    "local_domains_per_device": 1,
    "minions_per_local_domain": 8,
    "harts": ["h0"],
    "hart_stride": 2,
    "label_format": "m{minion}:{hart}",
    "direct_domain_format": "erbium0:minion{minion}",
    "local_domain_format": "erbium0:mram",
    "device_domain_format": "erbium0",
    "edge_pool_format": "erbium0:mram"
  }
}
